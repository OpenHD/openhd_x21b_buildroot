From 3a2cc2b4195d3831892854af52eb6f493e1ae139 Mon Sep 17 00:00:00 2001
From: Jiajian Wu <jair.wu@rock-chips.com>
Date: Tue, 17 Dec 2024 15:54:08 +0800
Subject: [PATCH 22/23] fix(draw): improve sw_img

1 Use fullscreen size buffer
2 Use arithmetic shifts instead of multiplication

Signed-off-by: Jiajian Wu <jair.wu@rock-chips.com>
---
 src/draw/sw/lv_draw_sw_img.c       |  2 +-
 src/draw/sw/lv_draw_sw_transform.c | 20 ++++++++++----------
 2 files changed, 11 insertions(+), 11 deletions(-)

diff --git a/src/draw/sw/lv_draw_sw_img.c b/src/draw/sw/lv_draw_sw_img.c
index 2f6dcf34a..241812701 100644
--- a/src/draw/sw/lv_draw_sw_img.c
+++ b/src/draw/sw/lv_draw_sw_img.c
@@ -28,7 +28,7 @@
 /*********************
  *      DEFINES
  *********************/
-#define MAX_BUF_SIZE (uint32_t) (4 * lv_display_get_horizontal_resolution(_lv_refr_get_disp_refreshing()) * lv_color_format_get_size(lv_display_get_color_format(_lv_refr_get_disp_refreshing())))
+#define MAX_BUF_SIZE (uint32_t) (lv_display_get_vertical_resolution(_lv_refr_get_disp_refreshing()) * lv_display_get_horizontal_resolution(_lv_refr_get_disp_refreshing()) * lv_color_format_get_size(lv_display_get_color_format(_lv_refr_get_disp_refreshing())))
 
 #ifndef LV_DRAW_SW_IMAGE
     #define LV_DRAW_SW_IMAGE(...)   LV_RESULT_INVALID
diff --git a/src/draw/sw/lv_draw_sw_transform.c b/src/draw/sw/lv_draw_sw_transform.c
index a0c5b14c0..695c98310 100644
--- a/src/draw/sw/lv_draw_sw_transform.c
+++ b/src/draw/sw/lv_draw_sw_transform.c
@@ -176,10 +176,10 @@ void lv_draw_sw_transform(lv_draw_unit_t * draw_unit, const lv_area_t * dest_are
         xs_step_256 = 0;
         ys_step_256_original = 0;
         if(dest_w > 1) {
-            xs_step_256 = (256 * xs_diff) / (dest_w - 1);
+            xs_step_256 = (xs_diff << 8) / (dest_w - 1);
         }
         if(dest_h > 1) {
-            ys_step_256_original = (256 * ys_diff) / (dest_h - 1);
+            ys_step_256_original = (ys_diff << 8) / (dest_h - 1);
         }
 
         xs_ups = xs1_ups + 0x80;
@@ -202,8 +202,8 @@ void lv_draw_sw_transform(lv_draw_unit_t * draw_unit, const lv_area_t * dest_are
             xs_step_256 = 0;
             ys_step_256 = 0;
             if(dest_w > 1) {
-                xs_step_256 = (256 * xs_diff) / (dest_w - 1);
-                ys_step_256 = (256 * ys_diff) / (dest_w - 1);
+                xs_step_256 = (xs_diff << 8) / (dest_w - 1);
+                ys_step_256 = (ys_diff << 8) / (dest_w - 1);
             }
 
             xs_ups = xs1_ups + 0x80;
@@ -622,8 +622,8 @@ static void transform_point_upscaled(point_transform_dsc_t * t, int32_t xin, int
                                      int32_t * yout)
 {
     if(t->angle == 0 && t->scale_x == LV_SCALE_NONE && t->scale_y == LV_SCALE_NONE) {
-        *xout = xin * 256;
-        *yout = yin * 256;
+        *xout = xin << 8;
+        *yout = yin << 8;
         return;
     }
 
@@ -631,16 +631,16 @@ static void transform_point_upscaled(point_transform_dsc_t * t, int32_t xin, int
     yin -= t->pivot.y;
 
     if(t->angle == 0) {
-        *xout = ((int32_t)(xin * 256 * 256 / t->scale_x)) + (t->pivot_x_256);
-        *yout = ((int32_t)(yin * 256 * 256 / t->scale_y)) + (t->pivot_y_256);
+        *xout = ((int32_t)((xin << 16) / t->scale_x)) + (t->pivot_x_256);
+        *yout = ((int32_t)((yin << 16) / t->scale_y)) + (t->pivot_y_256);
     }
     else if(t->scale_x == LV_SCALE_NONE && t->scale_y == LV_SCALE_NONE) {
         *xout = ((t->cosma * xin - t->sinma * yin) >> 2) + (t->pivot_x_256);
         *yout = ((t->sinma * xin + t->cosma * yin) >> 2) + (t->pivot_y_256);
     }
     else {
-        *xout = (((t->cosma * xin - t->sinma * yin) * 256 / t->scale_x) >> 2) + (t->pivot_x_256);
-        *yout = (((t->sinma * xin + t->cosma * yin) * 256 / t->scale_y) >> 2) + (t->pivot_y_256);
+        *xout = ((((t->cosma * xin - t->sinma * yin) << 8) / t->scale_x) >> 2) + (t->pivot_x_256);
+        *yout = ((((t->sinma * xin + t->cosma * yin) << 8) / t->scale_y) >> 2) + (t->pivot_y_256);
     }
 }
 
-- 
