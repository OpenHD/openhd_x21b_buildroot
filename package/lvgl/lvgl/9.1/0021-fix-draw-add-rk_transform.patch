+
+        /* Set the cores of scaler.
+         * -1 means according to the number of cpu */
+        #define LV_DRAW_RK_TRANSFORM_SCALER_CORES @BR2_LV_DRAW_RK_TRANSFORM_SCALER_CORES@
+    #endif
