From 9b3a16c7fe0d5f785311f480510570e889d0e57b Mon Sep 17 00:00:00 2001
From: Jiajian Wu <jair.wu@rock-chips.com>
Date: Fri, 17 Jan 2025 09:05:17 +0800
Subject: [PATCH 1/3] fix(drm): support more flexible config

Set connector:
export LV_DRM_CONNECTOR_NAME=HDMI
or
export LV_DRM_CONNECTOR_ID=189

Set plane:
export LV_DRM_PLANE_ID=109
or
export LV_DRM_PLANE_TYPE=OVERLAY
or
export LV_DRIVERS_SET_PLANE=OVERLAY

Set zpos:
export LV_DRM_PLANE_ZPOS=4

Set mode:
export lv_disp_width=1920
export lv_disp_height=1080
export lv_disp_fps=60

Set crop:
export lv_disp_crop=1

Or use config file include all configs in /tmp/lv_drm_setup.cfg or /userdata/lv_drm_setup.cfg:
LV_DRM_CONNECTOR_NAME=HDMI;LV_DRM_PLANE_TYPE=OVERLAY;lv_drm_plane_zpos=4

Signed-off-by: Jiajian Wu <jair.wu@rock-chips.com>
