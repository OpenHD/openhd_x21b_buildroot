From ed676dc7b37035235bd5d5aef2589bba85ba949f Mon Sep 17 00:00:00 2001
From: Jeffy Chen <jeffy.chen@rock-chips.com>
Date: Mon, 1 Apr 2024 16:24:09 +0800
Subject: [PATCH 2/4] render: egl: Fallback to gbm device fd

Signed-off-by: Jeffy Chen <jeffy.chen@rock-chips.com>
---
 render/egl.c | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/render/egl.c b/render/egl.c
index 19868ca..8e324be 100644
--- a/render/egl.c
+++ b/render/egl.c
@@ -952,6 +952,10 @@ static char *get_render_name(const char *name) {
 static int dup_egl_device_drm_fd(struct wlr_egl *egl) {
 	if (egl->device == EGL_NO_DEVICE_EXT || (!egl->exts.EXT_device_drm &&
 			!egl->exts.EXT_device_drm_render_node)) {
+		/* Fallback to gbm device fd */
+		if (egl->gbm_device)
+			return dup(gbm_device_get_fd(egl->gbm_device));
+
 		return -1;
 	}
 
