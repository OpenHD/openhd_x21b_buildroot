config BR2_PACKAGE_ROCKCHIP_MALI_SUPPORT
	bool
	select BR2_PACKAGE_ROCKCHIP_HAS_GPU

config BR2_PACKAGE_ROCKCHIP_MALI
	bool "rockchip-mali"
	depends on BR2_PACKAGE_ROCKCHIP_MALI_SUPPORT
	depends on BR2_INSTALL_LIBSTDCPP
	depends on BR2_TOOLCHAIN_USES_GLIBC
	depends on BR2_TOOLCHAIN_HAS_THREADS
	depends on BR2_aarch64 || (BR2_ARM_EABIHF && BR2_arm)
	select BR2_PACKAGE_LIBDRM
	help
	  Install the binary user-space components for the ARM Mali GPU.
	  This package requires a kernel with the ARM Mali GPU Kernel
	  Drivers enabled.

config BR2_PACKAGE_ROCKCHIP_MALI_UTGARD_400
	bool
	select BR2_PACKAGE_ROCKCHIP_MALI_SUPPORT

config BR2_PACKAGE_ROCKCHIP_MALI_UTGARD_450
	bool
	select BR2_PACKAGE_ROCKCHIP_MALI_SUPPORT

config BR2_PACKAGE_ROCKCHIP_MALI_MIDGARD_T76X
	bool
	select BR2_PACKAGE_ROCKCHIP_MALI_SUPPORT

config BR2_PACKAGE_ROCKCHIP_MALI_MIDGARD_T86X
	bool
	select BR2_PACKAGE_ROCKCHIP_MALI_SUPPORT

config BR2_PACKAGE_ROCKCHIP_MALI_BIFROST_G31
	bool
	select BR2_PACKAGE_ROCKCHIP_MALI_SUPPORT

config BR2_PACKAGE_ROCKCHIP_MALI_BIFROST_G52
	bool
	select BR2_PACKAGE_ROCKCHIP_MALI_SUPPORT

config BR2_PACKAGE_ROCKCHIP_MALI_VALHALL_G610
	bool
	select BR2_PACKAGE_ROCKCHIP_MALI_SUPPORT

if BR2_PACKAGE_ROCKCHIP_MALI

config BR2_PACKAGE_ROCKCHIP_MALI_GPU
        string
        default "utgard-400" if BR2_PACKAGE_ROCKCHIP_MALI_UTGARD_400
        default "utgard-450" if BR2_PACKAGE_ROCKCHIP_MALI_UTGARD_450
        default "midgard-t76x" if BR2_PACKAGE_ROCKCHIP_MALI_MIDGARD_T76X
        default "midgard-t86x" if BR2_PACKAGE_ROCKCHIP_MALI_MIDGARD_T86X
        default "bifrost-g31" if BR2_PACKAGE_ROCKCHIP_MALI_BIFROST_G31
        default "bifrost-g52" if BR2_PACKAGE_ROCKCHIP_MALI_BIFROST_G52
        default "valhall-g610" if BR2_PACKAGE_ROCKCHIP_MALI_VALHALL_G610

config BR2_PACKAGE_ROCKCHIP_MALI_VERSION
	string "version"
	default "r7p0" if BR2_PACKAGE_ROCKCHIP_MALI_UTGARD_400
	default "r7p0" if BR2_PACKAGE_ROCKCHIP_MALI_UTGARD_450
	default "r18p0" if BR2_PACKAGE_ROCKCHIP_MALI_MIDGARD_T76X
	default "r18p0" if BR2_PACKAGE_ROCKCHIP_MALI_MIDGARD_T86X
	default "g24p0" if BR2_PACKAGE_ROCKCHIP_MALI_BIFROST_G31
	default "g24p0" if BR2_PACKAGE_ROCKCHIP_MALI_BIFROST_G52
	default "g24p0" if BR2_PACKAGE_ROCKCHIP_MALI_VALHALL_G610

config BR2_PACKAGE_ROCKCHIP_MALI_SUB_VERSION
	string "sub version"
	default "r3p0" if BR2_PACKAGE_PX3SE
	default "r1p1" if BR2_PACKAGE_ROCKCHIP_MALI_UTGARD_400

choice
	prompt "optimize level"
	default BR2_PACKAGE_ROCKCHIP_MALI_OPTIMIZE_3
	help
	  Set the optimization level for rockchip-mali

config BR2_PACKAGE_ROCKCHIP_MALI_OPTIMIZE_3
	bool "optimization level 3"
	help
	  Built with -O3.

config BR2_PACKAGE_ROCKCHIP_MALI_OPTIMIZE_s
	bool "optimization level s"
	help
	  Built with -Os.

endchoice

config BR2_PACKAGE_ROCKCHIP_MALI_CUSTOM_PLATFORM
	string "custom platform"
	default ""

config BR2_PACKAGE_ROCKCHIP_MALI_HAS_DUMMY
	bool "dummy winsys"
	help
	  For dummy platform.

config BR2_PACKAGE_ROCKCHIP_MALI_HAS_WAYLAND
	bool "wayland winsys"
	default y
	depends on BR2_PACKAGE_WAYLAND
	help
	  For wayland platform.

config BR2_PACKAGE_ROCKCHIP_MALI_HAS_X11
	bool "X11 winsys"
	default y
	depends on BR2_PACKAGE_XORG7
	select BR2_PACKAGE_LIBXCB
	select BR2_PACKAGE_XLIB_LIBX11
	help
	  For X11 platform.

config BR2_PACKAGE_ROCKCHIP_MALI_HAS_GBM
	bool "GBM"
	default y if !BR2_PACKAGE_ROCKCHIP_MALI_HAS_DUMMY
	select BR2_PACKAGE_HAS_LIBGBM
	select BR2_PACKAGE_LIBGBM_HAS_FEATURE_FORMAT_MODIFIER_PLANE_COUNT
	select BR2_PACKAGE_LIBGBM_HAS_FEATURE_DMA_BUF
	help
	  For GBM platform.

config BR2_PACKAGE_ROCKCHIP_MALI_HAS_EGL
	bool "OpenGL EGL"
	default y
	select BR2_PACKAGE_HAS_LIBEGL

config BR2_PACKAGE_ROCKCHIP_MALI_HAS_EGL_WAYLAND
	bool "OpenGL EGL Wayland"
	default y
	depends on BR2_PACKAGE_ROCKCHIP_MALI_HAS_EGL
	depends on BR2_PACKAGE_ROCKCHIP_MALI_HAS_WAYLAND
	select BR2_PACKAGE_HAS_LIBEGL_WAYLAND

config BR2_PACKAGE_ROCKCHIP_MALI_HAS_GLES
	bool "OpenGL ES"
	default y
	select BR2_PACKAGE_HAS_LIBGLES

config BR2_PACKAGE_ROCKCHIP_MALI_HAS_OPENCL
	bool "OpenCL"
	default y
	select BR2_PACKAGE_HAS_LIBOPENCL

config BR2_PACKAGE_ROCKCHIP_MALI_HAS_VULKAN
	bool "Vulkan"
	select BR2_PACKAGE_VULKAN_LOADER

config BR2_PACKAGE_ROCKCHIP_MALI_VENDOR_PACKAGE
	bool "install as vendor package"
	depends on BR2_PACKAGE_MESA3D_GBM || !BR2_PACKAGE_ROCKCHIP_MALI_HAS_GBM
	depends on BR2_PACKAGE_MESA3D_OPENGL_EGL || \
		!BR2_PACKAGE_ROCKCHIP_MALI_HAS_EGL
	depends on BR2_PACKAGE_MESA3D_OPENGL_ES || \
		!BR2_PACKAGE_ROCKCHIP_MALI_HAS_GLES
	select BR2_PACKAGE_GLIBC_GEN_LD_CACHE

if !BR2_PACKAGE_ROCKCHIP_MALI_VENDOR_PACKAGE

config BR2_PACKAGE_PROVIDES_LIBEGL
	default "rockchip-mali" if BR2_PACKAGE_ROCKCHIP_MALI_HAS_EGL

config BR2_PACKAGE_PROVIDES_LIBGBM
	default "rockchip-mali" if BR2_PACKAGE_ROCKCHIP_MALI_HAS_GBM

config BR2_PACKAGE_PROVIDES_LIBGLES
	default "rockchip-mali" if BR2_PACKAGE_ROCKCHIP_MALI_HAS_GLES

endif

config BR2_PACKAGE_PROVIDES_LIBOPENCL
	default "rockchip-mali" if BR2_PACKAGE_ROCKCHIP_MALI_HAS_OPENCL

endif
